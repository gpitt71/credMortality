nodes = nodes_sequence,
nfold = nfolds
)
train_size <- 100L
test_size  <- 50L
sim_seed_train <- 123L
sim_seed_test  <- 456L
fit_seed       <- 999L
set.seed(sim_seed_train)
d_train <- simulateStenoT1(
n = train_size,
coefficient_age = 0.04,
coefficient_LDL = 0.05,
scenario = "beta",
competing_risks = FALSE
)
set.seed(sim_seed_test)
d_test <- simulateStenoT1(
n = test_size,
coefficient_age = 0.04,
coefficient_LDL = 0.05,
scenario = "beta",
competing_risks = FALSE
)
## keep same filtering convention as your simulation script
d_train <- d_train[time_cvd > 0.05]
d_test  <- d_test[time_cvd > 0.05]
times_eval <- c(5)
## same node setup as in simulation-beta-production.R
number_of_nodes <- 20L
nfolds <- 10L
nodes_sequence <- quantile(
d_train$time_cvd,
probs = seq(0, 1, length.out = number_of_nodes + 1L),
type = 1,
names = FALSE
)
xvars <- c(
"sex", "age", "diabetes_duration", "value_SBP", "value_LDL",
"value_HBA1C", "value_Smoking", "value_Motion",
"value_Albuminuria", "eGFR"
)
factor01_to_int <- function(x) {
if (is.factor(x)) {
x_chr <- as.character(x)
if (all(x_chr %in% c("0", "1"))) {
return(as.integer(x_chr))
}
if (nlevels(x) == 2L) {
return(as.integer(x) - 1L)
}
}
if (is.character(x)) {
if (all(x %in% c("0", "1"))) {
return(as.integer(x))
}
}
if (is.logical(x)) {
return(as.integer(x))
}
if (is.numeric(x)) {
return(as.integer(x))
}
stop("Unable to convert input to 0/1 coding.")
}
normalize_risk <- function(x, newdata, times, label) {
if (is.null(x)) {
stop(label, " returned NULL.")
}
if (length(times) == 1L) {
if (is.matrix(x) || is.data.frame(x)) {
x <- x[, 1, drop = TRUE]
}
x <- as.numeric(x)
if (length(x) != nrow(newdata)) {
stop(
label, " returned length ", length(x),
" but expected ", nrow(newdata), "."
)
}
return(x)
}
x <- as.matrix(x)
if (!identical(dim(x), c(nrow(newdata), length(times)))) {
stop(
label, " returned dimensions ",
paste(dim(x), collapse = " x "),
" but expected ",
paste(c(nrow(newdata), length(times)), collapse = " x "),
"."
)
}
x
}
predict_vistisen25 <- function(newdata, times = 5) {
dt <- as.data.table(copy(newdata))
female <- factor01_to_int(dt$sex)
smoking <- factor01_to_int(dt$value_Smoking)
regular_exercise <- factor01_to_int(dt$value_Motion)
no_regular_exercise <- 1L - regular_exercise
microalbuminuria <- as.integer(as.character(dt$value_Albuminuria) == "Micro")
macroalbuminuria <- as.integer(as.character(dt$value_Albuminuria) == "Macro")
log2_egfr <- log2(dt$eGFR)
alpha  <- -6.046429053
beta1  <-  0.040672727
beta2  <- -0.234111177
beta3  <-  0.013062752
beta4  <-  0.005814221
beta5  <-  0.082287009
beta6  <-  0.012209026
beta7  <-  0.437359313
beta8  <-  0.738916137
beta9  <- -0.404318528
beta10 <- -0.345596046
beta11 <-  0.204224209
beta12 <-  0.229279688
eta <- alpha +
beta1  * dt$age +
beta2  * female +
beta3  * dt$diabetes_duration +
beta4  * dt$value_SBP +
beta5  * dt$value_LDL +
beta6  * dt$value_HBA1C +
beta7  * microalbuminuria +
beta8  * macroalbuminuria +
beta9  * log2_egfr * as.integer(dt$age < 40) +
beta10 * log2_egfr * as.integer(dt$age >= 40) +
beta11 * smoking +
beta12 * no_regular_exercise
annual_rate <- exp(eta)
if (length(times) == 1L) {
return(as.numeric(1 - exp(-annual_rate * times)))
}
risk_mat <- sapply(times, function(tt) 1 - exp(-annual_rate * tt))
risk_mat <- as.matrix(risk_mat)
if (ncol(risk_mat) != length(times)) {
risk_mat <- matrix(risk_mat, nrow = nrow(dt), ncol = length(times))
}
colnames(risk_mat) <- paste0("t", times)
risk_mat
}
risk_vistisen <- normalize_risk(
predict_vistisen25(d_test, times = times_eval),
newdata = d_test,
times = times_eval,
label = "vistisen25"
)
lgam <- Learner_gam(
covariates = c(
"sex", "s(age)", "s(diabetes_duration)", "s(value_SBP)",
"s(value_LDL)", "s(value_HBA1C)", "value_Smoking",
"value_Motion", "value_Albuminuria", "s(eGFR)"
),
intercept = FALSE
)
lglmnet0 <- Learner_glmnet(
covariates = xvars,
cross_validation = FALSE,
intercept = TRUE,
lambda = 0
)
lglmnet1 <- Learner_glmnet(
covariates = xvars,
cross_validation = TRUE,
intercept = TRUE,
alpha = 1
)
lglmnet2 <- Learner_glmnet(
covariates = xvars,
cross_validation = TRUE,
intercept = TRUE,
alpha = 0
)
message("Fitting full Poisson Super Learner")
set.seed(fit_seed + 1L)
out_psl <- Superlearner(
d_train,
id = "id",
status = "status_cvd",
event_time = "time_cvd",
learners = list(
glm = lglmnet0,
lasso = lglmnet1,
ridge = lglmnet2,
gam = lgam
),
nodes = nodes_sequence,
nfold = nfolds
)
message("Fitting linear-only Poisson Super Learner")
set.seed(fit_seed + 2L)
out_psl_linear <- Superlearner(
d_train,
id = "id",
status = "status_cvd",
event_time = "time_cvd",
learners = list(
glm = lglmnet0,
lasso = lglmnet1,
ridge = lglmnet2
),
nodes = nodes_sequence,
nfold = nfolds
)
risk_psl <- normalize_risk(
predictRisk(
out_psl,
newdata = d_test,
times = times_eval,
cause = 1,
model = "sl"
),
newdata = d_test,
times = times_eval,
label = "psl"
)
risk_psl_linear <- normalize_risk(
predictRisk(
out_psl_linear,
newdata = d_test,
times = times_eval,
cause = 1,
model = "sl"
),
newdata = d_test,
times = times_eval,
label = "psl_linear"
)
risk_glm <- normalize_risk(
predictRisk(
out_psl,
newdata = d_test,
times = times_eval,
cause = 1,
model = "glm"
),
newdata = d_test,
times = times_eval,
label = "glm"
)
risk_lasso <- normalize_risk(
predictRisk(
out_psl,
newdata = d_test,
times = times_eval,
cause = 1,
model = "lasso"
),
newdata = d_test,
times = times_eval,
label = "lasso"
)
risk_ridge <- normalize_risk(
predictRisk(
out_psl,
newdata = d_test,
times = times_eval,
cause = 1,
model = "ridge"
),
newdata = d_test,
times = times_eval,
label = "ridge"
)
risk_gam <- normalize_risk(
predictRisk(
out_psl,
newdata = d_test,
times = times_eval,
cause = 1,
model = "gam"
),
newdata = d_test,
times = times_eval,
label = "gam"
)
predictions_all <- copy(d_test)[
,
.(
id,
time_cvd,
status_cvd,
vistisen25_risk_5y = risk_vistisen,
psl_risk_5y = risk_psl,
psl_linear_risk_5y = risk_psl_linear,
glm_risk_5y = risk_glm,
lasso_risk_5y = risk_lasso,
ridge_risk_5y = risk_ridge,
gam_risk_5y = risk_gam
)
]
print(head(predictions_all))
risk_gam
